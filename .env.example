# Shared
CATORA_ENVIRONMENT=development
CATORA_LOG_LEVEL=INFO

# API
CATORA_API_URL=http://localhost:8000
NEXT_PUBLIC_CATORA_API_URL=http://localhost:8000
CATORA_DATABASE_URL=postgresql+asyncpg://catora:catora@localhost:5432/catora
CATORA_REDIS_URL=redis://localhost:6379/0
CATORA_S3_ENDPOINT_URL=http://localhost:9000
CATORA_S3_ACCESS_KEY=catora
CATORA_S3_SECRET_KEY=change-me-in-production
CATORA_S3_BUCKET=catora
CATORA_CORS_ORIGINS=["http://localhost:3000"]

# Authentication
CATORA_AUTH_TOKEN_PEPPER=development-token-pepper-change-me
CATORA_FRONTEND_URL=http://localhost:3000
CATORA_SMTP_HOST=localhost
CATORA_SMTP_PORT=1025
CATORA_SMTP_FROM=Catora <no-reply@catora.local>
